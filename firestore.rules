rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Users ─────────────────────────────────────────────────────────────────
    match /users/{userId} {
      // Owner: full read + write of their own document.
      allow write: if request.auth != null
                   && request.auth.uid == userId;

      // Owner: read their own full document.
      allow read: if request.auth != null
                  && request.auth.uid == userId;

      // Discovery read: any authenticated user may read another user's
      // public profile fields when that user is live.  The client query
      // filters by isLive==true before requesting individual docs, so this
      // rule is only exercised for actually-live users.
      //
      // Permitted fields (read by the Nearby discovery query):
      //   firstName, age, bio, photoUrl, isLive, geohash, latitude, longitude,
      //   locationUpdatedAt, interestedIn, ageRangeMin, ageRangeMax, plan,
      //   hometown, occupation, height, lookingFor, opener
      //
      // Private fields (email, phone, doNotDisturb, credits, etc.) are not
      // restricted at the rule layer — Firestore rules can't project fields.
      // The client query only reads the fields it needs; no sensitive fields
      // are fetched by the discovery stream.
      allow read: if request.auth != null
                  && request.auth.uid != userId
                  && resource.data.isLive == true;

      // ── Blocked users subcollection ────────────────────────────────────────
      // Schema: users/{userId}/blockedUsers/{blockedUserId}
      //   blockedAt   : Timestamp
      //   displayName : String
      //   photoUrl    : String
      //
      // Write  — only the user who owns the list (the blocker).
      // Read   — the owner OR the person who was blocked.
      //          The "OR blocked" grant is intentionally narrow: it lets the
      //          security rule for icebreakers.create call exists() on
      //          "has this recipient blocked me?" without leaking the full
      //          blocked-users list to third parties.
      match /blockedUsers/{blockedUserId} {
        allow write:  if request.auth != null
                      && request.auth.uid == userId;

        allow read:   if request.auth != null
                      && (request.auth.uid == userId
                       || request.auth.uid == blockedUserId);
      }

      // ── Verification attempts audit ────────────────────────────────────────
      // Schema: users/{userId}/verificationAttempts/{attemptId}
      //   uid           : String — the owning user (== userId)
      //   kind          : 'live_selfie'   (Phase 1; future: 'phone' | 'id')
      //   method        : 'live_selfie' | 'test_mode_profile_photo'
      //                 |  'test_mode_demo'   (LiveVerificationMethod codec)
      //   outcome       : 'verified'      (Phase 1 only writes successes)
      //   eventType     : 'go_live' | 'redo'
      //   liveSessionId : String          (uid of the associated session)
      //   createdAt     : Timestamp (serverTimestamp)
      //
      // Append-only. Owner-only read/write — verification history is private
      // and must not leak to other users.  Validation pins the kind/outcome/
      // eventType domains so a future free-form misuse is rejected at the
      // rule layer rather than discovered at the analytics layer.
      match /verificationAttempts/{attemptId} {
        allow create: if request.auth != null
                      && request.auth.uid == userId
                      && request.resource.data.uid == userId
                      && request.resource.data.keys().hasAll(
                           ['uid', 'kind', 'method', 'outcome',
                            'eventType', 'liveSessionId', 'createdAt'])
                      && request.resource.data.kind in ['live_selfie']
                      && request.resource.data.outcome in ['verified']
                      && request.resource.data.eventType in
                           ['go_live', 'redo'];

        allow read:   if request.auth != null
                      && request.auth.uid == userId;

        allow update, delete: if false;
      }

      // ── Report dedup index ─────────────────────────────────────────────────
      // Schema: users/{userId}/reportedBy/{reporterId}
      //   reportedAt : Timestamp
      //   reason     : String
      //
      // Document ID == reporterId.  One doc per (reporter, reported) pair —
      // the natural key prevents duplicate reports from the same person.
      //
      // Write — only the reporter (auth.uid == reporterId).
      // Read  — only the owner of the profile being reported (userId).
      //         Owner needs read so the client can count unique reporters.
      match /reportedBy/{reporterId} {
        allow create: if request.auth != null
                      && request.auth.uid == reporterId
                      && request.resource.data.keys().hasAll(['reportedAt', 'reason'])
                      && request.resource.data.reason in
                           ['spam', 'harassment', 'inappropriate_content',
                            'fake_profile', 'other'];

        allow read:   if request.auth != null
                      && request.auth.uid == userId;

        allow update, delete: if false;
      }
    }

    // ── Icebreakers ───────────────────────────────────────────────────────────
    // create : only the sender; senderId in the new doc must equal their uid.
    //          Block enforcement (two exists() checks):
    //            a) sender must not be in recipient's blockedUsers list
    //            b) recipient must not be in sender's blockedUsers list
    //          Both checks use exists() which is allowed by the blockedUsers
    //          read rule above — each check reads a doc where auth.uid is
    //          either the owner (a) or the blocked person (b).
    // read   : sender or recipient (covers both get and list/query).
    // update : FORBIDDEN for clients.  All status transitions are owned by
    //          Cloud Functions (admin SDK), which means:
    //            sent → accepted    (respondToIcebreaker callable; atomic with
    //                                meetup creation + recipient credit debit)
    //            sent → declined    (respondToIcebreaker callable)
    //            sent → expired     (onIcebreakerExpired scheduled CF, TTL)
    //          Clients can never write 'accepted'/'declined' themselves, so no
    //          credit-spending state is forgeable from a malicious client.
    // delete : not permitted.
    match /icebreakers/{icebreakerId} {
      allow create: if request.auth != null
                    && request.resource.data.senderId == request.auth.uid
                    && request.resource.data.status == 'sent'
                    // Recipient has not blocked the sender.
                    && !exists(/databases/$(database)/documents/users/$(request.resource.data.recipientId)/blockedUsers/$(request.auth.uid))
                    // Sender has not blocked the recipient.
                    && !exists(/databases/$(database)/documents/users/$(request.auth.uid)/blockedUsers/$(request.resource.data.recipientId));

      allow read:   if request.auth != null
                    && (resource.data.senderId    == request.auth.uid
                     || resource.data.recipientId == request.auth.uid);

      allow update, delete: if false;
    }

    // ── Meetups ───────────────────────────────────────────────────────────────
    // State machine (status values):
    //   finding                       → both users seeing each other on the map
    //   talking                       → both pressed "I found them"; 10-min timer
    //   awaiting_post_talk_decision   → talk timer expired; decision screen open
    //   continued_private             → both chose we_got_this; chat unlocked
    //   no_match                      → at least one chose nice_meeting_you
    //   expired_finding               → find timer expired without both confirming
    //   matched (legacy), ended       → also accepted as terminal
    //
    // Client writes are tightly scoped:
    //   - Create the doc on icebreaker acceptance (status='finding',
    //     foundConfirmedBy:[], plus the identity fields).
    //   - Append own UID to foundConfirmedBy via arrayUnion (I-found-them tap).
    //   - All status/timer transitions are owned by Cloud Functions (admin SDK).
    //
    // Fields Cloud Functions set (clients cannot write these directly):
    //   findExpiresAt, talkExpiresAt, status (post-create), concludedAt,
    //   matchedAt.
    match /meetups/{meetupId} {

      allow read: if request.auth != null
                  && request.auth.uid in resource.data.participants;

      // Creation by the accepting recipient.  Must include both UIDs, the
      // initial 'finding' status, and an empty foundConfirmedBy array.
      // Timer (findExpiresAt) is stamped by the onMeetupCreated Cloud Function.
      allow create: if request.auth != null
                    && request.auth.uid in request.resource.data.participants
                    && request.resource.data.participants.size() == 2
                    && request.resource.data.status == 'finding'
                    && request.resource.data.foundConfirmedBy.size() == 0;

      // Participant updates are limited to appending the caller's own UID to
      // foundConfirmedBy.  Everything else (status, timers, conclude fields,
      // identity fields) is server-side only.
      //
      // The other participant's membership must not change: this prevents a
      // caller from arrayUnion'ing BOTH UIDs at once to unilaterally promote
      // the meetup to 'talking' (which onMeetupFoundConfirmed would then pick
      // up).  Combined with hasOnly(participants), the only permitted delta
      // is adding the caller's own UID.
      //
      // The outer parens around each `(... in foundConfirmedBy)` are
      // load-bearing — Firebase rules treat `in` and `==` at the same
      // precedence level with left-to-right associativity, so without them
      // the chain `X in OLD == X in NEW` parses as `((X in OLD) == X) in NEW`,
      // which evaluates to false for every legitimate write and silently
      // denies every "I found them" swipe.
      allow update: if request.auth != null
                    && request.auth.uid in resource.data.participants
                    && request.resource.data.diff(resource.data).affectedKeys()
                        .hasOnly(['foundConfirmedBy'])
                    && request.resource.data.foundConfirmedBy
                        .hasOnly(resource.data.participants)
                    && (
                      ((resource.data.participants[0] == request.auth.uid
                        ? resource.data.participants[1]
                        : resource.data.participants[0]) in resource.data.foundConfirmedBy)
                      ==
                      ((resource.data.participants[0] == request.auth.uid
                        ? resource.data.participants[1]
                        : resource.data.participants[0]) in request.resource.data.foundConfirmedBy)
                    );

      allow delete: if false;

      // ── Post-meet decisions ────────────────────────────────────────────────
      // Each user writes exactly one decision document for themselves.
      // Decisions are permanent — no updates or deletes permitted.
      match /decisions/{uid} {

        // Both participants may read all decisions under this meetup.
        // This lets clients show "waiting for the other person…" states.
        allow read: if request.auth != null
                    && request.auth.uid in
                       get(/databases/$(database)/documents/meetups/$(meetupId))
                       .data.participants;

        // A user may only create their own decision document, provided:
        //   - the document ID matches their UID (prevents impersonation)
        //   - they are a listed participant in the meetup
        //   - the parent meetup is in the awaiting_post_talk_decision phase
        //     (decisions submitted during finding/talking are rejected — the
        //     server-side function repeats this check as defence in depth)
        //   - the decision value is one of the two valid choices
        //   - the uid field in the payload also matches their uid
        allow create: if request.auth != null
                      && request.auth.uid == uid
                      && request.auth.uid in
                         get(/databases/$(database)/documents/meetups/$(meetupId))
                         .data.participants
                      && get(/databases/$(database)/documents/meetups/$(meetupId))
                         .data.status == 'awaiting_post_talk_decision'
                      && request.resource.data.decision in
                         ['we_got_this', 'nice_meeting_you']
                      && request.resource.data.uid == request.auth.uid;

        // Decisions are immutable once submitted.
        allow update, delete: if false;
      }

      // ── End requests ───────────────────────────────────────────────────────
      // Either participant may end a continued_private meetup at any time
      // (e.g. from chat "End match" action).  The onEndRequestCreated Cloud
      // Function picks up the first write and flips the meetup to 'ended',
      // which cascades through onMeetupTerminal to clear currentMeetupId on
      // both users and release them back to Nearby.
      //
      // Schema: meetups/{meetupId}/endRequests/{uid}
      //   uid         : String — the requester's own UID (= doc ID)
      //   requestedAt : Timestamp (serverTimestamp)
      //
      // Constraints:
      //   - Doc ID must equal caller UID (prevents impersonation).
      //   - Caller must be a participant.
      //   - Meetup must currently be in continued_private — earlier phases
      //     have their own exit paths (decisions, timers).
      //   - Immutable once written.
      match /endRequests/{uid} {

        allow read: if request.auth != null
                    && request.auth.uid in
                       get(/databases/$(database)/documents/meetups/$(meetupId))
                       .data.participants;

        allow create: if request.auth != null
                      && request.auth.uid == uid
                      && request.auth.uid in
                         get(/databases/$(database)/documents/meetups/$(meetupId))
                         .data.participants
                      && get(/databases/$(database)/documents/meetups/$(meetupId))
                         .data.status == 'continued_private'
                      && request.resource.data.uid == request.auth.uid;

        allow update, delete: if false;
      }

      // ── Finding-phase chat messages ────────────────────────────────────────
      // Lightweight chat scoped to the 'finding' phase so the two participants
      // can coordinate meeting up in person.  The subcollection lives under
      // the meetup, so it is automatically participant-gated and dies with
      // the meetup (no separate cleanup required).
      //
      // Schema: meetups/{meetupId}/findingMessages/{messageId}
      //   senderId  : String  — must equal the caller's UID
      //   text      : String  (1..500 chars)
      //   createdAt : Timestamp (serverTimestamp)
      //
      // Constraints:
      //   - Caller must be a participant of the parent meetup.
      //   - Read is allowed in any meetup phase (so the cancellee/timed-out
      //     panels can still show context) but writes require status=='finding'
      //     so chat naturally closes when the phase advances/terminates.
      //   - Messages are immutable once written.
      match /findingMessages/{messageId} {

        allow read: if request.auth != null
                    && request.auth.uid in
                       get(/databases/$(database)/documents/meetups/$(meetupId))
                       .data.participants;

        allow create: if request.auth != null
                      && request.auth.uid in
                         get(/databases/$(database)/documents/meetups/$(meetupId))
                         .data.participants
                      && get(/databases/$(database)/documents/meetups/$(meetupId))
                         .data.status == 'finding'
                      && request.resource.data.senderId == request.auth.uid
                      && request.resource.data.keys().hasAll(
                           ['senderId', 'text', 'createdAt'])
                      && request.resource.data.text is string
                      && request.resource.data.text.size() > 0
                      && request.resource.data.text.size() <= 500;

        allow update, delete: if false;
      }

      // ── Cancel requests (finding & talking phases) ─────────────────────────
      // Either participant may cancel the meetup while it is still in the
      // 'finding' or 'talking' phase (they tapped the X on MatchedScreen or
      // ColorMatchScreen and confirmed exit).  The onMeetupCancelRequestCreated
      // Cloud Function picks up the first write and flips the meetup to
      // 'cancelled_finding' or 'cancelled_talking' depending on the source
      // status, which then cascades through onMeetupTerminal to clear
      // currentMeetupId on both users and release them back to Nearby.
      //
      // Schema: meetups/{meetupId}/cancelRequests/{uid}
      //   uid         : String — the requester's own UID (= doc ID)
      //   requestedAt : Timestamp (serverTimestamp)
      //
      // Constraints:
      //   - Doc ID must equal caller UID (prevents impersonation).
      //   - Caller must be a participant.
      //   - Meetup must currently be in 'finding' OR 'talking' — once the
      //     decision phase opens, exit paths are decisions/end-requests.
      //   - Immutable once written.
      match /cancelRequests/{uid} {

        allow read: if request.auth != null
                    && request.auth.uid in
                       get(/databases/$(database)/documents/meetups/$(meetupId))
                       .data.participants;

        allow create: if request.auth != null
                      && request.auth.uid == uid
                      && request.auth.uid in
                         get(/databases/$(database)/documents/meetups/$(meetupId))
                         .data.participants
                      && get(/databases/$(database)/documents/meetups/$(meetupId))
                         .data.status in ['finding', 'talking']
                      && request.resource.data.uid == request.auth.uid;

        allow update, delete: if false;
      }

      // ── Talk-expired requests ─────────────────────────────────────────────
      // Either client writes its own subdoc the moment its local talk timer
      // hits 0.  onTalkExpiredRequestCreated picks up the first one and flips
      // the meetup to 'awaiting_post_talk_decision' immediately, eliminating
      // the up-to-60s lag that the scheduled onMeetupTalkExpired would
      // otherwise impose between local 0:00 and the user being able to
      // submit a decision.  Status guard keeps the request inert during any
      // other phase (the scheduler still runs as a backstop).
      //
      // Constraints:
      //   - Doc ID must equal caller UID (prevents impersonation).
      //   - Caller must be a participant.
      //   - Meetup must currently be in 'talking'.
      //   - Immutable once written.
      match /talkExpiredRequests/{uid} {

        allow read: if request.auth != null
                    && request.auth.uid in
                       get(/databases/$(database)/documents/meetups/$(meetupId))
                       .data.participants;

        allow create: if request.auth != null
                      && request.auth.uid == uid
                      && request.auth.uid in
                         get(/databases/$(database)/documents/meetups/$(meetupId))
                         .data.participants
                      && get(/databases/$(database)/documents/meetups/$(meetupId))
                         .data.status == 'talking'
                      && request.resource.data.uid == request.auth.uid;

        allow update, delete: if false;
      }
    }

    // ── Conversations ─────────────────────────────────────────────────────────
    // Created exclusively by the onMeetupDecisionWritten Cloud Function via
    // the admin SDK, which bypasses security rules.  No client may create a
    // conversation document directly — this is the key server-side gate that
    // guarantees mutual consent before chat unlocks.
    match /conversations/{conversationId} {

      // Read: only listed participants.
      allow read: if request.auth != null
                  && request.auth.uid in resource.data.participants;

      // CREATE IS FORBIDDEN FOR CLIENTS.
      // The Cloud Function (admin SDK) is the only writer here.
      allow create: if false;

      // Participants may update metadata only: lastMessage, lastMessageAt,
      // and per-user unread counts.  The protected fields below cannot be
      // changed by any client, preventing self-promotion or status forging.
      allow update: if request.auth != null
                    && request.auth.uid in resource.data.participants
                    && !request.resource.data.diff(resource.data).affectedKeys()
                        .hasAny(['status', 'participants', 'participantNames',
                                 'participantPhotos', 'sourceIcebreakerId',
                                 'meetupId', 'createdAt']);

      // Conversations are never deleted by clients.
      allow delete: if false;

      // ── Messages subcollection ───────────────────────────────────────────────
      // Access is participant-gated via get() on the parent conversation.
      // The extra read counts as one read-op per rule evaluation — acceptable
      // at MVP scale.
      match /messages/{messageId} {

        // Read: only participants of the parent conversation.
        allow read: if request.auth != null
                    && request.auth.uid in
                       get(/databases/$(database)/documents/conversations/$(conversationId))
                       .data.participants;

        // Create: participants only, as themselves, text type only.
        //   - senderId must equal the authenticated UID (prevents impersonation)
        //   - All required fields must be present
        //   - Only 'text' type allowed; 'system' is server-only
        //   - Conversation must still be active (status == 'active').
        //     A block sets status to 'blocked' via the Cloud Function, which
        //     immediately prevents new messages at the rules layer without
        //     requiring a separate blocked-users lookup here.
        allow create: if request.auth != null
                      && request.auth.uid in
                         get(/databases/$(database)/documents/conversations/$(conversationId))
                         .data.participants
                      && get(/databases/$(database)/documents/conversations/$(conversationId))
                         .data.status == 'active'
                      && request.resource.data.senderId == request.auth.uid
                      && request.resource.data.keys().hasAll(
                           ['senderId', 'text', 'type', 'createdAt'])
                      && request.resource.data.type == 'text';

        // Messages are immutable once written.
        allow update, delete: if false;
      }
    }

    // ── Matches (permanent ledger) ───────────────────────────────────────────
    // Immutable record of every meetup that ended in mutual 'we_got_this'.
    // Written exclusively by onMeetupDecisionWritten alongside the conversation
    // doc.  Distinct from `conversations` because conversations mutate on
    // every chat message (and can flip to status='blocked'), whereas a match
    // record is the frozen snapshot of "these two users matched at this
    // moment" — useful for analytics, profile showcases, or any feature
    // that needs match history independent of the chat's current state.
    //
    // No client write path of any kind.
    match /matches/{matchId} {

      // Read: only listed participants.
      allow read: if request.auth != null
                  && request.auth.uid in resource.data.participants;

      // All writes are server-only (admin SDK bypasses these rules).
      allow create, update, delete: if false;
    }

    // ── Live sessions ─────────────────────────────────────────────────────────
    // One active-or-terminal session doc per user, keyed by uid.  Structurally
    // enforces the "one active session per user" invariant — you cannot have
    // two docs, because the doc ID IS the uid.
    //
    // Schema (Phase 1, schemaVersion=1):
    //   uid                        : string  (== doc ID)
    //   status                     : 'active' | 'ended' | 'expired'
    //   endedReason                : 'manual' | 'blocked' | 'crash_recovered' | 'other' | null
    //   startedAt                  : Timestamp (serverTimestamp)
    //   expiresAt                  : Timestamp (startedAt + 1h)
    //   endedAt                    : Timestamp? (set when terminal)
    //   verificationMethod         : 'live_selfie' | 'test_mode_profile_photo' | 'test_mode_demo'
    //   verificationCompletedAt    : Timestamp
    //   currentMeetupId            : string?   (mirrored from users.currentMeetupId in Phase 1)
    //   visibilityState            : 'discoverable' | 'hidden_in_meetup'
    //                              |  'continued_private'
    //                              Only 'discoverable' grants cross-user read
    //                              access — see the get/list rules below.
    //                              All other values keep the session readable
    //                              by the owner alone.  visibilityState is
    //                              system-controlled: there is no user-facing
    //                              "ghost mode" / discoverable opt-out, so
    //                              Going Live always begins discoverable and
    //                              only flips to a hidden state via the
    //                              meetup state machine.
    //   lat, lng                   : number?
    //   geohash                    : string? (7-char; used by Nearby cell query)
    //   locationUpdatedAt          : Timestamp?
    //   maxDistanceMetersSnapshot  : number
    //   interestedInSnapshot       : string  (canonical lowercase preference)
    //   ageRangeMinSnapshot        : number
    //   ageRangeMaxSnapshot        : number
    //   liveCreditsAtStart         : number
    //   platform                   : 'ios' | 'android' | 'macos' | 'windows' | 'linux' | 'web'
    //   schemaVersion              : number (1 for this iteration)
    //   createdAt, updatedAt       : Timestamp
    //
    // Write  — only the session owner (uid == doc ID == auth.uid).
    //          Cloud Functions bypass rules and may also write (for meetup
    //          visibility transitions in Phase 2).
    // get    — owner always; OR any authenticated non-owner when the doc is
    //          live + discoverable.  Rules engine evaluates `resource.data`
    //          per single doc, so this matches Firestore's `get` semantics.
    // list   — any authenticated user, but only for documents where
    //          visibilityState=='discoverable' AND status=='active'.  These
    //          two equality predicates MUST be present on the Nearby query
    //          (they already are).  Splitting list out from get is the fix
    //          for Nearby's permission-denied: the previous combined `read`
    //          rule contained `request.auth.uid == userId` as a top-level
    //          disjunct, and Firestore could not statically prove the rule
    //          would pass for cross-user list operations from the query
    //          filters alone.
    match /live_sessions/{userId} {
      allow write: if request.auth != null
                   && request.auth.uid == userId;

      allow get: if request.auth != null
                 && (request.auth.uid == userId
                     || (resource.data.visibilityState == 'discoverable'
                         && resource.data.status == 'active'));

      allow list: if request.auth != null
                  && resource.data.visibilityState == 'discoverable'
                  && resource.data.status == 'active';
    }

    // ── Reverse block index ───────────────────────────────────────────────────
    // Mirrors the blockedUsers subcollection in the opposite direction.
    // Written by the blocker at block time so the blocked user can stream
    // the full set of UIDs that have blocked them — required for Nearby
    // discovery filtering in either direction.
    //
    // Schema: blockedBy/{userId}/blockers/{blockerUid}
    //   blockedAt : Timestamp
    //
    // Read  — only the blocked user (userId) may list/stream their own
    //         blocker list.  No third party can see who blocked whom.
    // Write — only the blocker (blockerUid) may create or delete their
    //         own entry.  Prevents impersonation: you cannot add yourself
    //         to someone else's reverse index, and you cannot remove a
    //         blocker entry that isn't yours.
    match /blockedBy/{userId}/blockers/{blockerUid} {
      allow read:   if request.auth != null
                    && request.auth.uid == userId;

      allow create: if request.auth != null
                    && request.auth.uid == blockerUid;

      allow delete: if request.auth != null
                    && request.auth.uid == blockerUid;

      allow update: if false;
    }

    // ── Reports ───────────────────────────────────────────────────────────────
    // Written by the reporting user.  Readable only by admins (server SDK).
    //
    // Schema: reports/{auto-id}
    //   Intake fields (client-writable on create):
    //     reporterId      : String  — must equal auth.uid (anti-impersonation)
    //     reportedId      : String  — uid of the reported user
    //     reason          : String  — one of the allowlist values
    //     note            : String  — optional free-text (may be empty)
    //     source          : String  — 'nearby' | 'chat' | 'profile'
    //     conversationId  : String? — present when source=='chat'
    //     createdAt       : Timestamp (serverTimestamp)
    //     status          : 'open' on create — the only legal initial value
    //
    //   Moderation fields (server-only — must be exactly null on create):
    //     reviewedAt   : Timestamp?
    //     reviewedBy   : String?    — admin uid
    //     adminNotes   : String?
    //
    // Forcing the four moderation fields to null at create time means the
    // doc lands in a known, well-formed shape that admin tooling can update
    // with a simple set(merge) without first having to pad missing fields.
    match /reports/{reportId} {
      allow create: if request.auth != null
                    && request.resource.data.reporterId == request.auth.uid
                    && request.resource.data.keys().hasAll(
                         ['reporterId', 'reportedId', 'reason', 'createdAt',
                          'status', 'reviewedAt', 'reviewedBy', 'adminNotes'])
                    && request.resource.data.reason in
                         ['spam', 'harassment', 'inappropriate_content',
                          'fake_profile', 'other']
                    && request.resource.data.status == 'open'
                    && request.resource.data.reviewedAt == null
                    && request.resource.data.reviewedBy == null
                    && request.resource.data.adminNotes == null;

      // Reports are write-once and read by admins only (server SDK bypasses rules).
      allow read, update, delete: if false;
    }

    // ── Public profiles ───────────────────────────────────────────────────────
    // Canonical public profile surface.  Mirrors a curated subset of the
    // fields on users/{uid} (firstName, age, bio, opener, hometown,
    // occupation, height, lookingFor, gender, orientation, interestedIn,
    // ageRangeMin, ageRangeMax, interests,
    // hobbies, photoUrls, primaryPhotoUrl, profileComplete, updatedAt).
    //
    // Read   — any authenticated user.  Discovery is gated separately via
    //          live_sessions; profiles/{uid} is the display source for cards
    //          and about-me sheets.  No sensitive fields live here.
    // Write  — owner only (uid == auth.uid).  Onboarding and edit-profile
    //          dual-write here alongside their existing users/{uid} writes.
    match /profiles/{uid} {
      allow read:  if request.auth != null;
      allow write: if request.auth != null
                   && request.auth.uid == uid;
    }

    // ── Canonical blocks ──────────────────────────────────────────────────────
    // Schema: blocks/{blockerId}_{blockedId}
    //   blockerId         : String  — auth.uid of the user who issued the block
    //   blockedId         : String  — uid of the user who was blocked
    //   status            : 'active' | 'released'
    //   source            : 'chat' | 'nearby' | 'profile'
    //   conversationId    : String?
    //   createdAt         : Timestamp (serverTimestamp)
    //   updatedAt         : Timestamp (serverTimestamp)
    //   releasedAt        : Timestamp? (set when status flips to 'released')
    //   blockedDisplayName: String?  (low-risk denormalised snapshot)
    //   blockedPhotoUrl   : String?
    //
    // The two runtime indexes (users/{uid}/blockedUsers/* and
    // blockedBy/{uid}/blockers/*) remain authoritative for runtime
    // enforcement (Nearby filter, security rules' exists() checks on
    // icebreakers/messages).  This collection is the canonical audit /
    // moderation surface — soft-released rows stay here forever even after
    // the runtime indexes are deleted.
    //
    // Read  — only the blocker.  We intentionally do not let the blocked
    //         party read their own block records; the blocked-by relationship
    //         is communicated to them via the reverse runtime index, which
    //         carries no provenance.
    // Write — only the blocker may create or update.  No deletes — soft-
    //         release via status='released' is the only retraction path.
    match /blocks/{blockId} {
      allow read:   if request.auth != null
                    && resource.data.blockerId == request.auth.uid;

      allow create: if request.auth != null
                    && request.resource.data.blockerId == request.auth.uid
                    && request.resource.data.keys().hasAll(
                         ['blockerId', 'blockedId', 'status', 'source',
                          'createdAt', 'updatedAt'])
                    && request.resource.data.status == 'active'
                    && request.resource.data.source in
                         ['chat', 'nearby', 'profile'];

      allow update: if request.auth != null
                    && resource.data.blockerId == request.auth.uid
                    && request.resource.data.blockerId == resource.data.blockerId
                    && request.resource.data.blockedId == resource.data.blockedId
                    && request.resource.data.status in ['active', 'released'];

      allow delete: if false;
    }
  }
}
